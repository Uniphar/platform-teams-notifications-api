{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AgentApplicationOptions": {
    "StartTypingTimer": false,
    "RemoveRecipientMention": false,
    "NormalizeMentions": false
  },
  "ConnectionsMap": [
    {
      "ServiceUrl": "*",
      "Connection": "ServiceConnection"
    }
  ],
  "CosmosStore": {
    "DatabaseName": "platform",
    "ContainerName": "teams-notifications-messages",
    "RetentionDays": 30
  },
  "FullyQualifiedNamespaceServiceBus": ""
}
